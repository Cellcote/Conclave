<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Conclave.App.ViewModels"
             x:Class="Conclave.App.Views.Shell.Sidebar"
             x:DataType="vm:ShellVm">
    <UserControl.Styles>
        <!-- Sidebar row hover/selected backgrounds. Bound to the row's DataContext
             (FilterVm / SessionVm / ProjectVm), all of which expose Tokens. Setters
             override the local Background, so the row Borders no longer bind it. -->
        <Style Selector="Border.filter-row">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.filter-row:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.Panel2}" />
        </Style>
        <Style Selector="Border.filter-row.selected">
            <Setter Property="Background" Value="{Binding Tokens.Panel}" />
        </Style>
        <Style Selector="Border.filter-row.selected:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.Panel}" />
        </Style>

        <Style Selector="Border.session-row">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.session-row:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.Panel2}" />
        </Style>
        <Style Selector="Border.session-row.active">
            <Setter Property="Background" Value="{Binding Tokens.Panel}" />
        </Style>
        <Style Selector="Border.session-row.active:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.Panel}" />
        </Style>

        <Style Selector="Border.project-header">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.project-header:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.Panel2}" />
        </Style>

        <Style Selector="Border.icon-btn">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.icon-btn:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.PanelHi}" />
        </Style>
    </UserControl.Styles>
    <Grid Background="{Binding Tokens.Bg}" RowDefinitions="Auto,*">
        <!-- Search pill (real input). The TextBox is borderless and lays inside the styled
             pill Border. ⌘P glyph hides while there's a query so the field doesn't compete. -->
        <Border Grid.Row="0" Margin="10,8,10,10"
                BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                CornerRadius="{Binding Tokens.RadMdCorner}" Padding="10,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="⌕" Foreground="{Binding Tokens.TextMute}" FontSize="12.5"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="SearchBox" Margin="8,0,0,0"
                         Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search"
                         BorderThickness="0" Background="Transparent" Padding="0"
                         FontSize="12.5" MinHeight="22" VerticalContentAlignment="Center"
                         KeyDown="OnSearchKeyDown" />
                <TextBlock Grid.Column="2" Text="⌘P" Foreground="{Binding Tokens.TextMute}"
                           FontSize="10.5" VerticalAlignment="Center"
                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                           IsVisible="{Binding !HasSearchQuery}" />
                <TextBlock Grid.Column="2" Text="✕" Foreground="{Binding Tokens.TextDim}"
                           FontSize="11" VerticalAlignment="Center"
                           IsVisible="{Binding HasSearchQuery}"
                           Cursor="Hand"
                           PointerPressed="OnSearchClearPressed" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="8,0" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Filters -->
                <ItemsControl ItemsSource="{Binding Filters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FilterVm">
                            <Border Classes="filter-row" Classes.selected="{Binding IsSelected}"
                                    Padding="10,6" CornerRadius="{Binding Tokens.RadSmCorner}"
                                    Cursor="Hand"
                                    PointerPressed="OnFilterPressed">
                                <Grid ColumnDefinitions="14,*,Auto">
                                    <Panel Grid.Column="0" Width="8" Height="8"
                                           VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border IsVisible="{Binding HasDot}" Width="6" Height="6"
                                                CornerRadius="3" Background="{Binding DotColor}" />
                                        <TextBlock IsVisible="{Binding !HasDot}" Text="◱" FontSize="10"
                                                   Foreground="{Binding Tokens.TextDim}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Panel>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                                               Margin="9,0,0,0"
                                               Foreground="{Binding TextBrush}"
                                               FontWeight="{Binding FontWeight}"
                                               FontSize="12.5" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Count}"
                                               Foreground="{Binding Tokens.TextMute}" FontSize="11"
                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="14" />

                <!-- Projects with nested sessions -->
                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectVm">
                            <StackPanel Margin="0,6,0,0" IsVisible="{Binding IsVisibleInTree}">
                                <Border Classes="project-header"
                                        Padding="4,2" CornerRadius="{Binding Tokens.RadSmCorner}"
                                        Cursor="Hand"
                                        PointerPressed="OnProjectHeaderPressed">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename" Click="OnRenameProjectMenu" />
                                            <MenuItem Header="Delete" Click="OnDeleteProjectMenu" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <TextBlock Text="{Binding ChevronGlyph}" FontSize="13"
                                               Foreground="{Binding Tokens.TextDim}"
                                               VerticalAlignment="Center"
                                               Margin="2,4,8,4" Width="14" TextAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{Binding Tokens.Text}" VerticalAlignment="Center"
                                               IsVisible="{Binding !IsEditing}"
                                               DoubleTapped="OnProjectNameDoubleTapped" />
                                    <TextBox Grid.Column="1" Text="{Binding EditingName, Mode=TwoWay}"
                                             FontSize="12" FontWeight="SemiBold"
                                             IsVisible="{Binding IsEditing}"
                                             AttachedToVisualTree="OnEditAttached"
                                             KeyDown="OnProjectRenameKeyDown"
                                             LostFocus="OnProjectRenameLostFocus" />
                                    <TextBlock Grid.Column="2" Text="{Binding SessionCount}"
                                               FontSize="10.5" Foreground="{Binding Tokens.TextMute}"
                                               VerticalAlignment="Center"
                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                                    <Border Grid.Column="3" Classes="icon-btn"
                                            Margin="6,0,0,0" Padding="6,2"
                                            CornerRadius="{Binding Tokens.RadXsCorner}"
                                            Cursor="Hand" ToolTip.Tip="New session in project"
                                            PointerPressed="OnNewSessionForProject">
                                        <TextBlock Text="+" FontSize="13"
                                                   Foreground="{Binding Tokens.TextDim}"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    </Grid>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Sessions}"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SessionVm">
                                            <Border Classes="session-row" Classes.active="{Binding IsActive}"
                                                    Margin="0,1" Padding="10,7,10,7"
                                                    CornerRadius="{Binding Tokens.RadSmCorner}"
                                                    Cursor="Hand"
                                                    IsVisible="{Binding IsVisibleInTree}"
                                                    PointerPressed="OnSessionPressed">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Rename" Click="OnRenameMenu" />
                                                        <MenuItem Header="Fork" Click="OnForkMenu"
                                                                  IsEnabled="{Binding !IsBusy}"
                                                                  IsVisible="{Binding $parent[UserControl].DataContext.Claude.SupportsForkSession}" />
                                                        <MenuItem Header="Delete" Click="OnDeleteMenu" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid ColumnDefinitions="22,*,Auto">
                                                    <Border Grid.Column="0" Width="6" Height="6"
                                                            CornerRadius="3"
                                                            Background="{Binding StatusColor}"
                                                            VerticalAlignment="Top" Margin="0,5,0,0"
                                                            HorizontalAlignment="Center" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12.5"
                                                                   Foreground="{Binding TitleBrush}"
                                                                   FontWeight="{Binding TitleFontWeight}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   IsVisible="{Binding !IsEditing}"
                                                                   DoubleTapped="OnSessionTitleDoubleTapped" />
                                                        <TextBox Text="{Binding EditingName, Mode=TwoWay}"
                                                                 FontSize="12.5"
                                                                 IsVisible="{Binding IsEditing}"
                                                                 AttachedToVisualTree="OnEditAttached"
                                                                 KeyDown="OnRenameKeyDown"
                                                                 LostFocus="OnRenameLostFocus" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Branch}" FontSize="10.5"
                                                                       Foreground="{Binding Tokens.TextMute}"
                                                                       FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <StackPanel Orientation="Horizontal" IsVisible="{Binding ShowDiff}">
                                                                <TextBlock Text=" · " FontSize="10.5"
                                                                           Foreground="{Binding Tokens.TextMute}" />
                                                                <TextBlock Text="{Binding AddText}" FontSize="10.5"
                                                                           Foreground="{Binding Tokens.Ok}"
                                                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                                                                <TextBlock Text=" " FontSize="10.5" />
                                                                <TextBlock Text="{Binding DelText}" FontSize="10.5"
                                                                           Foreground="{Binding Tokens.Err}"
                                                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" IsVisible="{Binding HasPr}">
                                                                <TextBlock Text=" · " FontSize="10.5"
                                                                           Foreground="{Binding Tokens.TextMute}" />
                                                                <TextBlock Text="{Binding PrText}" FontSize="10.5"
                                                                           Foreground="{Binding Tokens.TextMute}"
                                                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" MinWidth="14" Height="14"
                                                            CornerRadius="7" Padding="4,0"
                                                            Background="{Binding Tokens.AccentMid}"
                                                            IsVisible="{Binding HasUnread}"
                                                            VerticalAlignment="Top" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding Unread}"
                                                                   Foreground="{Binding Tokens.AccentBrush}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.RowSpan="2" Width="1" HorizontalAlignment="Right"
                Background="{Binding Tokens.Border}" />
    </Grid>
</UserControl>
