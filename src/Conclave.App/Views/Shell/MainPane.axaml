<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Conclave.App.ViewModels"
             xmlns:shell="clr-namespace:Conclave.App.Views.Shell"
             x:Class="Conclave.App.Views.Shell.MainPane"
             x:DataType="vm:ShellVm">
    <UserControl.Styles>
        <!-- Subtle hover on the inactive Terminal/Plan/Logs segmented tabs.
             Active tabs already carry a panel background, so they're skipped. -->
        <Style Selector="Border.seg-tab">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.seg-tab:pointerover">
            <Setter Property="Background" Value="{Binding Tokens.PanelHi}" />
        </Style>
    </UserControl.Styles>
    <Grid Background="{Binding Tokens.Bg}" RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{Binding Tokens.Border}" BorderThickness="0,0,0,1"
                Padding="28,12,24,14">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveSession.Title, FallbackValue=''}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{Binding Tokens.Text}"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="{Binding ActiveSession.StatusColor}"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.StatusLabel}" FontSize="12"
                                   Foreground="{Binding Tokens.TextDim}" VerticalAlignment="Center" />
                        <TextBlock Text="·" Foreground="{Binding Tokens.TextMute}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.Branch}" FontSize="11.5"
                                   Foreground="{Binding Tokens.TextDim}"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="·" Foreground="{Binding Tokens.TextMute}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.Model}" FontSize="12"
                                   Foreground="{Binding Tokens.TextDim}" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding ActiveSession.HasPr}">
                            <TextBlock Text="·" Foreground="{Binding Tokens.TextMute}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ActiveSession.PrText}" FontSize="11.5"
                                       Foreground="{Binding Tokens.TextDim}"
                                       FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Segmented control -->
                <Border Grid.Column="1" BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                        CornerRadius="{Binding Tokens.RadMdCorner}" Padding="2"
                        Background="{Binding Tokens.Panel}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                Background="{Binding Tokens.Bg}" BorderBrush="{Binding Tokens.Border}"
                                BorderThickness="1" Name="SegTerminal"
                                PointerPressed="OnSegTerminal"
                                IsVisible="{Binding IsTerminalView}">
                            <TextBlock Text="Terminal" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.Text}" />
                        </Border>
                        <Border Classes="seg-tab" Cursor="Hand"
                                Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                BorderThickness="1" BorderBrush="Transparent"
                                PointerPressed="OnSegTerminal"
                                IsVisible="{Binding !IsTerminalView}">
                            <TextBlock Text="Terminal" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.TextDim}" />
                        </Border>

                        <Border Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                Background="{Binding Tokens.Bg}" BorderBrush="{Binding Tokens.Border}"
                                BorderThickness="1"
                                PointerPressed="OnSegPlan"
                                IsVisible="{Binding IsPlanView}">
                            <TextBlock Text="Plan" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.Text}" />
                        </Border>
                        <Border Classes="seg-tab" Cursor="Hand"
                                Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                BorderThickness="1" BorderBrush="Transparent"
                                PointerPressed="OnSegPlan"
                                IsVisible="{Binding !IsPlanView}">
                            <TextBlock Text="Plan" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.TextDim}" />
                        </Border>

                        <Border Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                Background="{Binding Tokens.Bg}" BorderBrush="{Binding Tokens.Border}"
                                BorderThickness="1"
                                PointerPressed="OnSegLogs"
                                IsVisible="{Binding IsLogsView}">
                            <TextBlock Text="Logs" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.Text}" />
                        </Border>
                        <Border Classes="seg-tab" Cursor="Hand"
                                Padding="11,4" CornerRadius="{Binding Tokens.RadSmCorner}"
                                BorderThickness="1" BorderBrush="Transparent"
                                PointerPressed="OnSegLogs"
                                IsVisible="{Binding !IsLogsView}">
                            <TextBlock Text="Logs" FontSize="12" FontWeight="Medium"
                                       Foreground="{Binding Tokens.TextDim}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Transcript -->
        <ScrollViewer Grid.Row="1" x:Name="TranscriptScroller"
                      HorizontalScrollBarVisibility="Disabled" Padding="34,8,34,14"
                      IsVisible="{Binding IsTerminalView}">
            <StackPanel>
            <ItemsControl x:Name="TranscriptList" ItemsSource="{Binding ActiveSession.Transcript}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TranscriptMessageVm">
                        <StackPanel>
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Fork from here" Click="OnForkFromHereMenu"
                                              IsEnabled="{Binding !$parent[UserControl].DataContext.ActiveSession.IsBusy}" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <!-- Auto-resume separator: replaces the user bubble for the
                                 synthetic "continue" prompt sent by StallDetectionService.
                                 A thin centred line so the resumed assistant text reads as
                                 a continuation of the prior reply rather than a new turn. -->
                            <Grid IsVisible="{Binding IsAutoResume}"
                                  ColumnDefinitions="*,Auto,*" Margin="0,16,0,12">
                                <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                                        Background="{Binding Tokens.Border}" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1" Text="resumed after wake"
                                           FontSize="10" FontStyle="Italic"
                                           Foreground="{Binding Tokens.TextMute}"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                                        Background="{Binding Tokens.Border}" Margin="12,0,0,0" />
                            </Grid>
                            <!-- Header row (hidden on consecutive same-role messages, and
                                 hidden entirely for auto-resume rows so the separator stands
                                 alone). -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Margin="0,22,0,8"
                                        IsVisible="{Binding ShouldShowHeader}">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{Binding Tokens.AccentBrush}"
                                        VerticalAlignment="Center" IsVisible="{Binding IsAssistant}" />
                                <TextBlock Text="{Binding HeaderText}" FontSize="11" FontWeight="Medium"
                                           Foreground="{Binding Tokens.TextDim}" />
                            </StackPanel>
                            <!-- Body — markdown for assistant messages, plain selectable
                                 text for user. Hidden when empty so back-to-back tool-only
                                 messages don't accumulate phantom line-height. Hidden for
                                 auto-resume rows so the separator alone marks the seam. -->
                            <shell:MarkdownView Source="{Binding Content}"
                                                Tokens="{Binding Tokens}"
                                                IsVisible="{Binding ShouldShowContent}" />
                            <!-- Tool calls. Margin-top kept tiny so a chain of tool-only
                                 assistant chunks reads as one tight block. -->
                            <ItemsControl ItemsSource="{Binding Tools}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToolCallVm">
                                        <!-- ColumnDefinitions: 46 Kind · * Target · Auto (bounded) status+meta.
                                             Meta MaxWidth keeps it from eating the target column on long
                                             permission-request messages. -->
                                        <Border BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                                                CornerRadius="{Binding Tokens.RadSmCorner}" Padding="10,6">
                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="46,*,Auto" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Kind}" FontSize="10"
                                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                                               Foreground="{Binding Tokens.TextDim}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Target}"
                                                               FontSize="11.5"
                                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                                               Foreground="{Binding Tokens.Text}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                Spacing="6" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusGlyph}" FontSize="11.5"
                                                                   Foreground="{Binding StatusBrush}" />
                                                        <TextBlock Text="{Binding Meta}" FontSize="11.5"
                                                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                                                   Foreground="{Binding Tokens.TextDim}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="200" />
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Permission ask: shows when claude is waiting on the user
                                                     to allow or deny this specific tool invocation. -->
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            IsVisible="{Binding IsAwaitingApproval}">
                                                    <TextBlock Text="Allow this tool to run?" FontSize="11.5"
                                                               Foreground="{Binding Tokens.TextDim}"
                                                               VerticalAlignment="Center" />
                                                    <Button Content="Approve" FontSize="11.5" Padding="8,3"
                                                            Click="OnApprovePermission" />
                                                    <Button Content="Deny" FontSize="11.5" Padding="8,3"
                                                            Click="OnDenyPermission" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Throbber: tells the user we're waiting on claude. Bound to IsBusy so it
                 covers both the pre-stream wait and tool-running periods. Hidden when the
                 session is stalled — the stalled banner takes its slot. -->
            <StackPanel Classes="throbber" Orientation="Horizontal" Spacing="8"
                        Margin="0,18,0,4"
                        IsVisible="{Binding ActiveSession.IsBusyAndNotStalled, FallbackValue=False}">
                <StackPanel.Styles>
                    <Style Selector="StackPanel.throbber > Border">
                        <Style.Animations>
                            <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </StackPanel.Styles>
                <Border Width="6" Height="6" CornerRadius="3"
                        Background="{Binding Tokens.AccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Claude is thinking…" FontSize="12"
                           FontStyle="Italic" Foreground="{Binding Tokens.TextDim}"
                           VerticalAlignment="Center" />
            </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Plan view -->
        <ContentControl Grid.Row="1" IsVisible="{Binding IsPlanView}">
            <shell:PlanView />
        </ContentControl>
        <!-- Logs view -->
        <ContentControl Grid.Row="1" IsVisible="{Binding IsLogsView}">
            <shell:LogsView />
        </ContentControl>

        <!-- Composer -->
        <!-- Stalled banner: pinned above the composer (outside the transcript ScrollViewer)
             so it's always visible when the active session is stalled, regardless of how
             far up the user has scrolled. Auto-collapsed when not stalled. -->
        <Border Grid.Row="2"
                IsVisible="{Binding ActiveSession.IsStalled, FallbackValue=False}"
                Margin="28,8,28,0" Padding="12,8"
                BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                CornerRadius="{Binding Tokens.RadSmCorner}"
                Background="{Binding Tokens.Panel}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <Border Width="6" Height="6" CornerRadius="3"
                        Background="{Binding Tokens.Warn}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Session stalled — Claude hasn't responded in a while."
                           FontSize="12" FontStyle="Italic"
                           Foreground="{Binding Tokens.TextDim}" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Resume" Click="OnResumeStalled"
                        Padding="10,3" FontSize="11.5" FontWeight="Medium"
                        Background="Transparent"
                        BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                        Foreground="{Binding Tokens.Text}"
                        CornerRadius="{Binding Tokens.RadSmCorner}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" x:Name="ComposerBorder" Margin="28,6,28,24"
                BorderBrush="{Binding Tokens.BorderHi}" BorderThickness="1"
                CornerRadius="{Binding Tokens.RadMdCorner}" Background="{Binding Tokens.Panel}"
                Padding="14,12"
                DragDrop.AllowDrop="True">
            <StackPanel Spacing="8">
                <TextBox x:Name="ComposerBox"
                         Text="{Binding ActiveSession.ComposerDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                         PlaceholderText="Continue the session…"
                         FontSize="13.5"
                         BorderThickness="0"
                         Background="Transparent"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="28" MaxHeight="220"
                         Padding="0"
                         IsEnabled="{Binding HasActiveSession}">
                    <!-- FluentTheme draws a thick accent border on focus regardless
                         of BorderThickness="0". Override the focus- and hover-state
                         resources so the outer composer Border is the sole indicator. -->
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                        <Thickness x:Key="TextControlBorderThemeThicknessPointerOver">0</Thickness>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    </TextBox.Resources>
                </TextBox>

                <ItemsControl ItemsSource="{Binding ActiveSession.ComposerAttachments}"
                              IsVisible="{Binding ActiveSession.HasComposerAttachments, FallbackValue=False}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AttachmentVm">
                            <Border Margin="0,0,6,6" Padding="8,3,4,3"
                                    BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                                    CornerRadius="{Binding Tokens.RadXsCorner}"
                                    Background="{Binding Tokens.Panel2}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="📎" FontSize="11"
                                               Foreground="{Binding Tokens.TextDim}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding FileName}" FontSize="11.5"
                                               Foreground="{Binding Tokens.Text}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="220"
                                               VerticalAlignment="Center" />
                                    <Button Content="✕" FontSize="10"
                                            Padding="4,0" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{Binding Tokens.TextMute}"
                                            Click="OnRemoveAttachment" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                    <Border Grid.Column="0" Padding="6,3" BorderBrush="{Binding Tokens.Border}"
                            BorderThickness="1" CornerRadius="{Binding Tokens.RadXsCorner}" Margin="0,0,6,0">
                        <TextBlock Text="@ file" FontSize="11" Foreground="{Binding Tokens.TextDim}" />
                    </Border>
                    <Border Grid.Column="1" Padding="6,3" BorderBrush="{Binding Tokens.Border}"
                            BorderThickness="1" CornerRadius="{Binding Tokens.RadXsCorner}" Margin="0,0,6,0">
                        <TextBlock Text="/plan" FontSize="11" Foreground="{Binding Tokens.TextDim}"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                    </Border>
                    <Border Grid.Column="2" Padding="6,3" BorderBrush="{Binding Tokens.Border}"
                            BorderThickness="1" CornerRadius="{Binding Tokens.RadXsCorner}">
                        <TextBlock Text="{Binding ActiveSession.Model, FallbackValue='Sonnet 4.5'}"
                                   FontSize="11" Foreground="{Binding Tokens.TextDim}" />
                    </Border>
                    <TextBlock Grid.Column="4" Text="⏎" FontSize="11"
                               Foreground="{Binding Tokens.TextMute}"
                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               IsVisible="{Binding !ActiveSession.IsBusy, FallbackValue=True}" />
                    <Button Grid.Column="5" Content="Send" Click="OnComposerSend"
                            IsEnabled="{Binding ActiveSession.CanSend, FallbackValue=False}"
                            IsVisible="{Binding !ActiveSession.IsBusy, FallbackValue=True}"
                            Padding="12,5" FontSize="12" FontWeight="SemiBold"
                            Background="{Binding Tokens.Text}" Foreground="{Binding Tokens.Bg}"
                            BorderThickness="0"
                            CornerRadius="{Binding Tokens.RadSmCorner}" />
                    <Button Grid.Column="5" Content="Stop" Click="OnComposerStop"
                            IsVisible="{Binding ActiveSession.IsBusy, FallbackValue=False}"
                            Padding="12,5" FontSize="12" FontWeight="SemiBold"
                            Background="Transparent"
                            BorderBrush="{Binding Tokens.Err}" BorderThickness="1"
                            Foreground="{Binding Tokens.Err}"
                            CornerRadius="{Binding Tokens.RadSmCorner}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
