<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Conclave.App.ViewModels"
             x:Class="Conclave.App.Views.Shell.PreferencesModal"
             x:DataType="vm:ShellVm">
    <Panel IsVisible="{Binding IsPreferencesOpen}" IsHitTestVisible="{Binding IsPreferencesOpen}"
           KeyDown="OnModalKeyDown"
           Focusable="True">
        <Border Background="#A6000000" PointerPressed="OnBackdropPressed" />

        <Border Width="500"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{Binding Tokens.Bg}"
                BorderBrush="{Binding Tokens.BorderHi}" BorderThickness="1"
                CornerRadius="{Binding Tokens.RadLgCorner}"
                Padding="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" OffsetY="20" Opacity="0.5" Color="Black" />
            </Border.Effect>

            <StackPanel Spacing="18">
                <TextBlock Text="Preferences" FontSize="16" FontWeight="SemiBold"
                           Foreground="{Binding Tokens.Text}" />

                <StackPanel Spacing="10">
                    <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding Tokens.TextDim}" LetterSpacing="1.5" />

                    <CheckBox Content="Notify me when Claude is done or is asking a question"
                              IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"
                              Foreground="{Binding Tokens.Text}" FontSize="12.5" />

                    <TextBlock Text="System notifications fire only when Conclave isn't focused."
                               FontSize="11" Foreground="{Binding Tokens.TextMute}"
                               TextWrapping="Wrap" Margin="24,0,0,0" />
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="AUTO-CLEANUP" FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding Tokens.TextDim}" LetterSpacing="1.5" />

                    <CheckBox Content="Delete sessions whose PR has been merged"
                              IsChecked="{Binding AutoCleanupEnabled, Mode=TwoWay}"
                              Foreground="{Binding Tokens.Text}" FontSize="12.5" />

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0,0,0"
                                IsEnabled="{Binding AutoCleanupEnabled}">
                        <TextBlock Text="After" FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Center" />
                        <TextBox Name="DaysInput" Width="56"
                                 Text="{Binding AutoCleanupDays, Mode=OneWay}"
                                 LostFocus="OnDaysCommit" KeyDown="OnDaysKey"
                                 FontSize="12"
                                 FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                        <TextBlock Text="days" FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Idle sessions whose PR was merged at least this long ago will be removed — worktree, branch, and transcript."
                               FontSize="11" Foreground="{Binding Tokens.TextMute}"
                               TextWrapping="Wrap" Margin="24,0,0,0" />

                    <Button Content="Clean up now" Click="OnCleanupNow"
                            HorizontalAlignment="Left" Margin="24,4,0,0"
                            Background="Transparent"
                            BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                            CornerRadius="{Binding Tokens.RadSmCorner}" Padding="10,5"
                            Foreground="{Binding Tokens.Text}" FontSize="11.5" FontWeight="Medium" />
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <Button Grid.Column="1" Content="Done" Click="OnDone"
                            Background="{Binding Tokens.Text}" BorderThickness="0"
                            CornerRadius="{Binding Tokens.RadSmCorner}" Padding="14,5"
                            Foreground="{Binding Tokens.Bg}" FontSize="12" FontWeight="SemiBold" />
                </Grid>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
