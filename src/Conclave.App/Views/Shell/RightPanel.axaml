<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Conclave.App.ViewModels"
             x:Class="Conclave.App.Views.Shell.RightPanel"
             x:DataType="vm:ShellVm"
             ClipToBounds="True">
    <Border BorderBrush="{Binding Tokens.Border}" BorderThickness="1,0,0,0"
            Background="{Binding Tokens.Bg}" ClipToBounds="True">
        <ScrollViewer Padding="22,18,22,22"
                      HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding HasActiveSession}">
            <StackPanel Spacing="26">
                <!-- Session section — left-aligned key/value table. Auto column for
                     labels, * column for values. Values wrap (the * column gives the
                     value TextBlock a hard arrange width) so long mono paths break
                     across lines instead of overflowing the panel. -->
                <StackPanel>
                    <TextBlock Text="SESSION" FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding Tokens.TextDim}" Margin="0,0,0,12"
                               LetterSpacing="1.5" />
                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="14" RowSpacing="9">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Status"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Row="0" Grid.Column="1"
                                    Orientation="Horizontal" Spacing="6">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="{Binding ActiveSession.StatusColor}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ActiveSession.StatusLabel}" FontSize="12"
                                       Foreground="{Binding Tokens.Text}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Branch"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActiveSession.Branch}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Worktree"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActiveSession.Worktree}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Base"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActiveSession.BaseBranch}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Model"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ActiveSession.Model}"
                                   FontSize="12" Foreground="{Binding Tokens.Text}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Started"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ActiveSession.StartedFormatted}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="PID"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ActiveSession.PidFormatted}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Cost"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Top"
                                   IsVisible="{Binding ActiveSession.HasCost}" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ActiveSession.TotalCostFormatted}"
                                   FontSize="12"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                   Foreground="{Binding Tokens.Text}"
                                   IsVisible="{Binding ActiveSession.HasCost}" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Permissions"
                                   FontSize="12" Foreground="{Binding Tokens.TextDim}"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Row="8" Grid.Column="1" x:Name="PermissionPicker"
                                  SelectedItem="{Binding ActiveSession.PermissionMode, Mode=OneWay}"
                                  SelectionChanged="OnPermissionModeChanged"
                                  HorizontalAlignment="Stretch" MinWidth="0"
                                  FontSize="12" Padding="8,2"
                                  Background="Transparent"
                                  BorderBrush="{Binding Tokens.Border}" BorderThickness="1">
                            <ComboBoxItem Content="default" />
                            <ComboBoxItem Content="acceptEdits" />
                            <ComboBoxItem Content="bypassPermissions" />
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Pull request section -->
                <StackPanel IsVisible="{Binding ActiveSession.HasPr}">
                    <TextBlock Text="PULL REQUEST" FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding Tokens.TextDim}" Margin="0,0,0,12"
                               LetterSpacing="1.5" />
                    <Border BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                            CornerRadius="{Binding Tokens.RadMdCorner}" Padding="12,10"
                            ClipToBounds="True">
                        <StackPanel Spacing="7">
                            <DockPanel LastChildFill="True">
                                <Border DockPanel.Dock="Left" Padding="5,1"
                                        BorderBrush="{Binding Tokens.Border}" BorderThickness="1"
                                        CornerRadius="{Binding Tokens.RadXsCorner}" Margin="0,0,8,0">
                                    <TextBlock Text="DRAFT" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{Binding Tokens.TextDim}" LetterSpacing="1" />
                                </Border>
                                <TextBlock Text="{Binding ActiveSession.PrText}" FontSize="11.5"
                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                           Foreground="{Binding Tokens.Text}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="6">
                                <TextBlock Text="{Binding ActiveSession.Pr.Branch}" FontSize="11.5"
                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                           Foreground="{Binding Tokens.Text}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" Text="→" FontSize="11.5"
                                           Foreground="{Binding Tokens.TextMute}" />
                                <TextBlock Grid.Column="2" Text="{Binding ActiveSession.Pr.Base}" FontSize="11.5"
                                           FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                           Foreground="{Binding Tokens.Text}"
                                           TextWrapping="Wrap" />
                            </Grid>
                            <TextBlock Text="{Binding ActiveSession.Pr.MetaTail}" FontSize="11"
                                       Foreground="{Binding Tokens.TextDim}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Diff section -->
                <StackPanel IsVisible="{Binding ActiveSession.ShowDiff}">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                        <TextBlock Text="DIFF ·" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{Binding Tokens.TextDim}" LetterSpacing="1.5" />
                        <TextBlock Text="{Binding ActiveSession.Diff.Files, StringFormat='{}{0} FILES'}" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{Binding Tokens.TextDim}" LetterSpacing="1.5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ActiveSession.AddText}" FontSize="12"
                                   Foreground="{Binding Tokens.Ok}"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                        <TextBlock Text="{Binding ActiveSession.DelText}" FontSize="12"
                                   Foreground="{Binding Tokens.Err}"
                                   FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace" />
                    </StackPanel>
                    <!-- File-change rows: same Auto/* table pattern as the SESSION block.
                         Path wraps to break long file paths inside the column. -->
                    <ItemsControl ItemsSource="{Binding ActiveSession.Diff.Changes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileChangeVm">
                                <Grid ColumnDefinitions="14,*,Auto" ColumnSpacing="6"
                                      Margin="0,0,0,4">
                                    <TextBlock Text="{Binding KindLetter}"
                                               FontSize="11.5"
                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                               Foreground="#7BB87B" VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding Path}"
                                               FontSize="11.5"
                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                               TextWrapping="Wrap" VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="2" Text="{Binding AddDel}"
                                               FontSize="11.5"
                                               FontFamily="ui-monospace,SFMono-Regular,Menlo,monospace"
                                               VerticalAlignment="Top" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
